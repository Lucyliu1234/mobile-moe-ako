+    if (slot_out == nullptr || !pc.external_payload_arena ||
+        !pc.packed_payload_arena || pc.payload_base != 0 ||
+        !isBaseProjectionName(proj_name)) {
+      return false;
+    }
+    const auto up = caches_.find(std::to_string(layer) + ":up:v3");
+    const auto down = caches_.find(std::to_string(layer) + ":down:v3");
+    if (up == caches_.end() || down == caches_.end() ||
+        up->second.payload_arena != pc.payload_arena ||
+        down->second.payload_arena != pc.payload_arena) {
+      return false;
+    }
+    const auto up_it = up->second.entries.find(expert);
+    const auto down_it = down->second.entries.find(expert);
+    if (up_it == up->second.entries.end() ||
+        down_it == down->second.entries.end()) {
+      return false;
+    }
+    const int slot = up_it->second.slot;
+    if (slot < 0 || down_it->second.slot != slot) return false;
+    for (const auto& kv : pc.entries) {
+      if (kv.second.slot == slot) return false;
+    }
+    CacheEntry entry = makeCacheEntry(slot, /*is_prewarm=*/false);
+    entry.expert = expert;
+    entry.resource_key =
+        "core-slot:" + pc.key + ":expert:" + std::to_string(expert);
+    entry.bytes = pc.payload_stride;
+    auto free_it = std::find(pc.free_slots.begin(), pc.free_slots.end(), slot);
+    if (free_it != pc.free_slots.end()) pc.free_slots.erase(free_it);
+    const auto inserted = pc.entries.emplace(expert, entry);
+    if (!inserted.second) return false;
+    *slot_out = slot;
+    return true;
+  }
