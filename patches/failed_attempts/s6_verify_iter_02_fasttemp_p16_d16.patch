+struct MmapTouchProfile {
+  int64_t madvise_us = 0;
+  int64_t touch_loop_us = 0;
+  uint64_t pages = 0;
+  int64_t minor_faults = 0;
+  int64_t major_faults = 0;
+};
+
+static int64_t elapsedUs(const std::chrono::steady_clock::time_point& a,
+                         const std::chrono::steady_clock::time_point& b) {
+  return std::chrono::duration_cast<std::chrono::microseconds>(b - a).count();
+}
+
+static long usageMinorFaults(const rusage& usage) {
+  return usage.ru_minflt;
+}
+
+static long usageMajorFaults(const rusage& usage) {
+  return usage.ru_majflt;
+}
+
+static MmapTouchProfile touchMmapPagesProfiled(const uint8_t* base, size_t size) {
+  MmapTouchProfile profile;
+  if (base == nullptr || size == 0) return profile;
   const long page_size = sysconf(_SC_PAGESIZE);
   const size_t stride = page_size > 0 ? static_cast<size_t>(page_size) : 4096U;
+  rusage usage_before{};
+  rusage usage_after{};
+  const auto madvise_t0 = std::chrono::steady_clock::now();
   madvise(const_cast<uint8_t*>(base), size, MADV_WILLNEED);
+  const auto madvise_t1 = std::chrono::steady_clock::now();
+  profile.madvise_us = elapsedUs(madvise_t0, madvise_t1);
+  (void)getrusage(RUSAGE_SELF, &usage_before);
+  const auto touch_t0 = std::chrono::steady_clock::now();
   volatile uint8_t sink = 0;
   for (size_t off = 0; off < size; off += stride) {
     sink ^= base[off];
+    ++profile.pages;
   }
   sink ^= base[size - 1];
   (void)sink;
+  const auto touch_t1 = std::chrono::steady_clock::now();
+  (void)getrusage(RUSAGE_SELF, &usage_after);
+  profile.touch_loop_us = elapsedUs(touch_t0, touch_t1);
+  profile.minor_faults =
+      usageMinorFaults(usage_after) - usageMinorFaults(usage_before);
+  profile.major_faults =
+      usageMajorFaults(usage_after) - usageMajorFaults(usage_before);
+  return profile;
+}
+
+static void touchMmapPages(const uint8_t* base, size_t size) {
+  (void)touchMmapPagesProfiled(base, size);
 }
 
