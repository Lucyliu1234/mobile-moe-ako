+  void markExternalExpertPayloadResidentNoLock(const GpuV3CoreMiss& miss) {
+    if (!expert_payload_arena_ || !expert_miss_full_materialize_) return;
+    const auto mark = [&](const char* proj_name, const char* suffix) {
+      auto it = caches_.find(std::to_string(miss.request.layer) + ":" +
+                             proj_name + ":v3");
+      if (it == caches_.end()) return;
+      ProjectionCache& sibling = it->second;
+      if (!sibling.external_payload_arena ||
+          sibling.payload_arena == nullptr ||
+          sibling.payload_base == 0 ||
+          sibling.payload_stride == 0 ||
+          sibling.entries.find(miss.expert) != sibling.entries.end()) {
+        return;
+      }
+      CacheEntry entry = makeCacheEntry(miss.slot, /*is_prewarm=*/false);
+      entry.expert = miss.expert;
+      entry.resource_key = miss.request.key + suffix;
+      entry.bytes = miss.request.bytes;
+      sibling.entries.emplace(miss.expert, std::move(entry));
+    };
+    mark("up", ":up");
+    mark("down", ":down");
+  }
