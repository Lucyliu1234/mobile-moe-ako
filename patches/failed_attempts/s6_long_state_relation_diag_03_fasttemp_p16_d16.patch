+struct MmapResidencySample {
+  uint64_t pages = 0;
+  uint64_t resident_pages = 0;
+  int64_t elapsed_us = 0;
+};
+
+static MmapResidencySample sampleMmapResidency(const uint8_t* base,
+                                               size_t size) {
+  MmapResidencySample out;
+  if (base == nullptr || size == 0) return out;
+  const long page_size_raw = sysconf(_SC_PAGESIZE);
+  const size_t page_size =
+      page_size_raw > 0 ? static_cast<size_t>(page_size_raw) : 4096U;
+  const uintptr_t addr = reinterpret_cast<uintptr_t>(base);
+  const uintptr_t page_addr = addr - (addr % page_size);
+  const size_t page_delta = static_cast<size_t>(addr - page_addr);
+  const size_t covered = size + page_delta;
+  out.pages = static_cast<uint64_t>((covered + page_size - 1) / page_size);
+  if (out.pages == 0) return out;
+  std::vector<unsigned char> vec(static_cast<size_t>(out.pages), 0);
+  const auto t0 = std::chrono::steady_clock::now();
+  const int rc =
+      mincore(reinterpret_cast<void*>(page_addr),
+              static_cast<size_t>(out.pages) * page_size, vec.data());
+  const auto t1 = std::chrono::steady_clock::now();
+  out.elapsed_us = std::chrono::duration_cast<std::chrono::microseconds>(
+                       t1 - t0)
+                       .count();
+  if (rc != 0) return out;
+  for (unsigned char v : vec) {
+    if ((v & 1U) != 0) ++out.resident_pages;
+  }
+  return out;
+}
