+  ProjectionCache* findGpuV3ProjectionCacheNoLock(int layer,
+                                                  const char* proj_name) {
+    const std::string key =
+        std::to_string(layer) + ":" + proj_name + ":v3";
+    auto it = caches_.find(key);
+    return it == caches_.end() ? nullptr : &it->second;
+  }
+
+  void removeFreeSlotNoLock(ProjectionCache& pc, int slot) {
+    pc.free_slots.erase(
+        std::remove(pc.free_slots.begin(), pc.free_slots.end(), slot),
+        pc.free_slots.end());
+  }
+
+  void eraseExternalPayloadSiblingSlotNoLock(ProjectionCache& pc,
+                                             int expert,
+                                             int slot) {
+    for (auto it = pc.entries.begin(); it != pc.entries.end();) {
+      if (it->second.expert == expert || it->second.slot == slot) {
+        if (scheduler_ != nullptr) {
+          scheduler_->eraseResource(it->second.resource_key);
+        }
+        it = pc.entries.erase(it);
+      } else {
+        ++it;
+      }
+    }
+    removeFreeSlotNoLock(pc, slot);
+  }
+
+  void recordExternalPayloadSiblingEntryNoLock(ProjectionCache& pc,
+                                               int layer,
+                                               int expert,
+                                               int slot,
+                                               const CacheEntry& base_entry) {
+    if (!pc.external_payload_arena || pc.payload_base == 0 ||
+        pc.payload_arena == nullptr) {
+      return;
+    }
+    eraseExternalPayloadSiblingSlotNoLock(pc, expert, slot);
+    CacheEntry entry = base_entry;
+    entry.expert = expert;
+    entry.slot = slot;
+    entry.resource_key =
+        "core-slot:" + pc.key + ":expert:" + std::to_string(expert);
+    entry.bytes = pc.weight_stride + pc.scale_stride + pc.scale2_stride;
+    pc.entries.emplace(expert, entry);
+    ++stats_.res_record;
+    ++stats_.res_sibling_missing;
+    if (scheduler_ != nullptr) {
+      scheduler_->touchResident(
+          entry.resource_key,
+          HybridPrefetchScheduler::ResourceKind::Core,
+          entry.bytes,
+          layer,
+          HybridPrefetchScheduler::Protection::Required,
+          /*speculative=*/false,
+          HybridPrefetchScheduler::ResourceState::Resident,
+          HybridPrefetchScheduler::ExternalStorageRef{
+              "", 0, entry.bytes, layer, pc.proj_name, false});
+    }
+  }
+
+  void invalidateExternalPayloadSiblingsNoLock(const ProjectionCache& pc,
+                                               int expert,
+                                               int slot) {
+    if (!pc.external_payload_arena || pc.payload_base != 0 ||
+        pc.payload_arena == nullptr) {
+      return;
+    }
+    ProjectionCache* up_pc = findGpuV3ProjectionCacheNoLock(pc.layer, "up");
+    ProjectionCache* down_pc = findGpuV3ProjectionCacheNoLock(pc.layer, "down");
+    if (up_pc != nullptr && up_pc->payload_arena == pc.payload_arena) {
+      eraseExternalPayloadSiblingSlotNoLock(*up_pc, expert, slot);
+    }
+    if (down_pc != nullptr && down_pc->payload_arena == pc.payload_arena) {
+      eraseExternalPayloadSiblingSlotNoLock(*down_pc, expert, slot);
+    }
+  }
+
+  void recordExternalPayloadSiblingsNoLock(const ProjectionCache& pc,
