+static void touchRequiredMmapPayloadPages(const uint8_t* base, size_t size) {
+  if (base == nullptr || size == 0) return;
+  const long page_size = sysconf(_SC_PAGESIZE);
+  const size_t page_stride =
+      page_size > 0 ? static_cast<size_t>(page_size) : 4096U;
+  const size_t stride =
+      size >= (1U << 20) ? page_stride * 16U : page_stride;
+  madvise(const_cast<uint8_t*>(base), size, MADV_WILLNEED);
+  volatile uint8_t sink = 0;
+  for (size_t off = 0; off < size; off += stride) {
+    sink ^= base[off];
+  }
+  sink ^= base[size - 1];
+  (void)sink;
+}
